### Variables (VS Code REST Client style)
@baseUrl = http://localhost:8080
@accessToken =
@refreshToken =
@tokoToken = replace-with-your-toko-token
@merchantUUID = replace-with-payment-gateway-merchant-uuid
@gatewayClient = replace-with-panel-name
@trxId =
@partnerRefNo =
@inquiryId = 0
@callbackSecret =
@newUserName = Team Admin
@newUserEmail = team.admin@example.com
@newUserPassword = secret123
@newUserRole = user
@targetUserID =
@targetRole = admin
@targetBankID =

### Register
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "name": "Dev User",
  "email": "dev.user@example.com",
  "password": "secret123"
}

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "dev.user@example.com",
  "password": "secret123"
}

### Refresh
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Logout
POST {{baseUrl}}/api/v1/auth/logout
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Me
GET {{baseUrl}}/api/v1/user/me
Authorization: Bearer {{accessToken}}

### Change Current User Password
PATCH {{baseUrl}}/api/v1/user/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "current_password": "secret123",
  "new_password": "secret12345",
  "confirm_password": "secret12345"
}

### Dashboard Overview (Realtime Source)
GET {{baseUrl}}/api/v1/dashboard/overview
Authorization: Bearer {{accessToken}}

### Transaction History
GET {{baseUrl}}/api/v1/transactions/history?limit=50
Authorization: Bearer {{accessToken}}

### Create User (role actor must not be 'user')
POST {{baseUrl}}/api/v1/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "{{newUserName}}",
  "email": "{{newUserEmail}}",
  "password": "{{newUserPassword}}",
  "role": "{{newUserRole}}",
  "is_active": true
}

### List Users (search + role filter + pagination)
GET {{baseUrl}}/api/v1/users?limit=10&offset=0&q=admin&role=admin
Authorization: Bearer {{accessToken}}

### Update User Role (only dev/superadmin)
PATCH {{baseUrl}}/api/v1/users/{{targetUserID}}/role
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "role": "{{targetRole}}"
}

### Toggle User Active Status (admin+ within hierarchy)
PATCH {{baseUrl}}/api/v1/users/{{targetUserID}}/active
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "is_active": false
}

### Delete User (admin+ within hierarchy)
DELETE {{baseUrl}}/api/v1/users/{{targetUserID}}
Authorization: Bearer {{accessToken}}

### List Banks (current authenticated user only)
GET {{baseUrl}}/api/v1/banks?limit=10&offset=0&q=bca
Authorization: Bearer {{accessToken}}

### Search Bank Options from Payment Catalog
GET {{baseUrl}}/api/v1/banks/payment-options?limit=20&q=mandiri
Authorization: Bearer {{accessToken}}

### Create Bank for Current User
POST {{baseUrl}}/api/v1/banks
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "payment_id": 1,
  "account_name": "PT GUE CONTROL",
  "account_number": "1234567890"
}

### Delete Bank for Current User
DELETE {{baseUrl}}/api/v1/banks/{{targetBankID}}
Authorization: Bearer {{accessToken}}

### List Tokos (maks 3 toko / user)
GET {{baseUrl}}/api/v1/tokos
Authorization: Bearer {{accessToken}}

### Toko Workspace (search + pagination)
GET {{baseUrl}}/api/v1/tokos/workspace?limit=10&offset=0&q=alpha
Authorization: Bearer {{accessToken}}

### Create Toko
POST {{baseUrl}}/api/v1/tokos
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Toko Alpha",
  "callback_url": "https://merchant.example.com/callback"
}

### Update Toko Profile
PATCH {{baseUrl}}/api/v1/tokos/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Toko Alpha Updated",
  "callback_url": "https://merchant.example.com/callback-updated"
}

### Regenerate Toko Token
POST {{baseUrl}}/api/v1/tokos/1/regenerate-token
Authorization: Bearer {{accessToken}}

### Testing Page - Generate QRIS via Authenticated Session
POST {{baseUrl}}/api/v1/testing/generate-qris
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "toko_id": 1,
  "username": "player-testing-01",
  "amount": 10000,
  "expire": 600,
  "custom_ref": "TESTING001"
}

### Testing Page - Callback Readiness Check
POST {{baseUrl}}/api/v1/testing/callback-readiness
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "toko_id": 1
}

### Generate QRIS/VA (auth pakai bearer toko token)
POST {{baseUrl}}/api/v1/payments/gateway/generate
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "username": "player-001",
  "amount": 10000,
  "expire": 1200,
  "custom_ref": "ORDER123"
}

### Check Payment Status V2
POST {{baseUrl}}/api/v1/payments/gateway/check-status/{{trxId}}
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "client": "{{gatewayClient}}"
}

### Inquiry Transfer
POST {{baseUrl}}/api/v1/payments/gateway/inquiry
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "client": "{{gatewayClient}}",
  "amount": 25000,
  "bank_code": "014",
  "account_number": "1234567890",
  "type": 2
}

### Transfer Fund
POST {{baseUrl}}/api/v1/payments/gateway/transfer
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "client": "{{gatewayClient}}",
  "amount": 25000,
  "bank_code": "014",
  "account_number": "1234567890",
  "type": 2,
  "inquiry_id": {{inquiryId}}
}

### Check Transfer Status
POST {{baseUrl}}/api/v1/payments/gateway/transfer/check-status/{{partnerRefNo}}
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "client": "{{gatewayClient}}"
}

### Get Gateway Balance
POST {{baseUrl}}/api/v1/payments/gateway/balance
Authorization: Bearer {{tokoToken}}
Content-Type: application/json

{
  "client": "{{gatewayClient}}"
}

### Simulate QRIS Callback
POST {{baseUrl}}/api/v1/payments/gateway/callback/qris
Content-Type: application/json
X-Callback-Secret: {{callbackSecret}}

{
  "amount": 10000,
  "terminal_id": "player-001",
  "merchant_id": "{{merchantUUID}}",
  "trx_id": "{{trxId}}",
  "rrn": "112233445566",
  "custom_ref": "ORDER123",
  "vendor": "NOBU",
  "status": "success",
  "created_at": "2026-03-21T10:00:00Z",
  "finish_at": "2026-03-21T10:01:00Z"
}

### Simulate Transfer Callback
POST {{baseUrl}}/api/v1/payments/gateway/callback/transfer
Content-Type: application/json
X-Callback-Secret: {{callbackSecret}}

{
  "amount": 25000,
  "partner_ref_no": "{{partnerRefNo}}",
  "status": "success",
  "transaction_date": "2026-03-21T10:05:00Z",
  "merchant_id": "{{merchantUUID}}"
}
